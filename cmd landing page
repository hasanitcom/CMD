<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CMD - Chan Whira Digital</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Poppins',sans-serif;
    }

    body{
      background:#050816;
      color:white;
      overflow-x:hidden;
    }

    a{
      text-decoration:none;
    }

    .container{
      width:90%;
      max-width:1200px;
      margin:auto;
    }

    header{
      padding:20px 0;
      position:sticky;
      top:0;
      z-index:1000;
      background:rgba(0,0,0,0.6);
      backdrop-filter:blur(10px);
    }

    nav{
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .logo{
      font-size:30px;
      font-weight:900;
    }

    .logo span{
      color:#2d8cff;
    }

    .menu a{
      margin-left:25px;
      color:white;
      font-weight:500;
      transition:0.3s;
    }

    .menu a:hover{
      color:#2d8cff;
    }

    .hero{
      padding:100px 0;
      background:linear-gradient(135deg,#050816,#071c4d,#0b1020);
    }

    .hero-wrap{
      display:grid;
      grid-template-columns:1fr 1fr;
      align-items:center;
      gap:50px;
    }

    .hero h1{
      font-size:65px;
      line-height:1.1;
      font-weight:900;
      margin-bottom:20px;
    }

    .hero h1 span{
      color:#2d8cff;
    }

    .hero p{
      color:#cbd5e1;
      font-size:18px;
      line-height:1.8;
      margin-bottom:30px;
    }

    .btn{
      display:inline-block;
      padding:16px 35px;
      border-radius:15px;
      background:#2d8cff;
      color:white;
      font-weight:700;
      transition:0.3s;
      box-shadow:0 10px 30px rgba(45,140,255,0.4);
    }

    .btn:hover{
      transform:translateY(-5px);
      background:#1b6fe0;
    }

    .hero-img img{
      width:100%;
      border-radius:30px;
      box-shadow:0 20px 60px rgba(0,0,0,0.5);
    }

    .services{
      padding:100px 0;
      background:#09101f;
    }

    .title{
      text-align:center;
      margin-bottom:60px;
    }

    .title h2{
      font-size:50px;
      font-weight:900;
    }

    .title span{
      color:#2d8cff;
    }

    .title p{
      margin-top:15px;
      color:#cbd5e1;
    }

    .service-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:25px;
    }

    .card{
      background:#111827;
      padding:35px;
      border-radius:25px;
      transition:0.3s;
      border:1px solid rgba(255,255,255,0.08);
    }

    .card:hover{
      transform:translateY(-10px);
      border-color:#2d8cff;
    }

    .icon{
      width:70px;
      height:70px;
      background:#2d8cff;
      border-radius:20px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:30px;
      margin-bottom:20px;
    }

    .card h3{
      margin-bottom:15px;
      font-size:25px;
    }

    .card p{
      color:#cbd5e1;
      line-height:1.8;
    }

    .pricing{
      padding:100px 0;
      background:linear-gradient(135deg,#0a1020,#071c4d);
    }

    .price-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
      gap:30px;
      margin-top:60px;
    }

    .price-card{
      background:white;
      color:#111827;
      border-radius:30px;
      padding:40px;
      text-align:center;
      box-shadow:0 20px 60px rgba(0,0,0,0.3);
    }

    .price-card.dark{
      background:#111827;
      color:white;
      border:2px solid #2d8cff;
    }

    .price-card h3{
      font-size:28px;
      margin-bottom:10px;
    }

    .price{
      font-size:60px;
      font-weight:900;
      margin:20px 0;
      color:#2d8cff;
    }

    .price-card ul{
      list-style:none;
      text-align:left;
      margin-top:20px;
    }

    .price-card ul li{
      margin-bottom:15px;
      font-size:17px;
    }

    .cta{
      padding:100px 0;
      text-align:center;
    }

    .cta-box{
      background:linear-gradient(135deg,#111827,#071c4d);
      padding:70px 30px;
      border-radius:40px;
      border:1px solid rgba(45,140,255,0.3);
    }

    .cta-box h2{
      font-size:55px;
      margin-bottom:20px;
      font-weight:900;
    }

    .cta-box h2 span{
      color:#2d8cff;
    }

    .cta-box p{
      color:#cbd5e1;
      max-width:700px;
      margin:auto;
      margin-bottom:35px;
      line-height:1.8;
    }

    footer{
      padding:40px 0;
      border-top:1px solid rgba(255,255,255,0.08);
      text-align:center;
      color:#cbd5e1;
    }

    footer h3{
      font-size:28px;
      margin-bottom:15px;
    }

    footer h3 span{
      color:#2d8cff;
    }

    @media(max-width:900px){
      .hero-wrap{
        grid-template-columns:1fr;
      }

      .hero h1{
        font-size:45px;
      }

      .title h2{
        font-size:40px;
      }

      .cta-box h2{
        font-size:40px;
      }

      .menu{
        display:none;
      }
    }
  </style>
</head>
